{"datasets": [{"name": "ds_uc_overview", "displayName": "UC Asset Overview", "queryLines": ["SELECT table_type, COUNT(*) as asset_count FROM system.information_schema.tables WHERE table_catalog NOT IN ('system','samples') GROUP BY table_type ORDER BY asset_count DESC"]}, {"name": "ds_uc_tags", "displayName": "UC Tag Coverage", "queryLines": ["SELECT tag_name, COUNT(DISTINCT concat(catalog_name,'.',schema_name,'.',table_name)) as tagged_tables FROM system.information_schema.table_tags WHERE catalog_name NOT IN ('system','samples') GROUP BY tag_name ORDER BY tagged_tables DESC LIMIT 10"]}, {"name": "ds_uc_access", "displayName": "UC Access Distribution", "queryLines": ["SELECT privilege_type, COUNT(*) as grant_count, COUNT(DISTINCT grantee) as distinct_grantees FROM system.information_schema.table_privileges WHERE table_catalog NOT IN ('system','samples') GROUP BY privilege_type ORDER BY grant_count DESC"]}, {"name": "ds_uc_undocumented", "displayName": "UC Undocumented Tables", "queryLines": ["SELECT t.table_catalog, t.table_schema, t.table_name, t.table_owner, t.table_type FROM system.information_schema.tables t LEFT JOIN system.information_schema.table_tags tt ON t.table_catalog = tt.catalog_name AND t.table_schema = tt.schema_name AND t.table_name = tt.table_name WHERE t.table_catalog NOT IN ('system','samples') AND tt.tag_name IS NULL AND (t.comment IS NULL OR t.comment = '') ORDER BY t.table_catalog, t.table_schema LIMIT 30"]}, {"name": "ds_uc_tables_by_catalog", "displayName": "UC Tables by Catalog", "queryLines": ["SELECT table_catalog, COUNT(*) as table_count FROM system.information_schema.tables WHERE table_catalog NOT IN ('system','samples') GROUP BY table_catalog ORDER BY table_count DESC"]}, {"name": "ds_wd_counters", "displayName": "Compliance Counters", "queryLines": ["SELECT COUNT(*) as total_open, SUM(CASE WHEN severity='critical' THEN 1 ELSE 0 END) as critical_open, SUM(CASE WHEN severity='high' THEN 1 ELSE 0 END) as high_open, COUNT(DISTINCT resource_id) as resources_violated FROM serverless_stable_s0v155_catalog.watchdog.violations WHERE status='open'"]}, {"name": "ds_wd_resources", "displayName": "Resources Scanned", "queryLines": ["SELECT COUNT(DISTINCT resource_id) as total_resources, COUNT(DISTINCT resource_type) as resource_types FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory WHERE scan_id = (SELECT MAX(scan_id) FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory)"]}, {"name": "ds_wd_domain", "displayName": "Violations by Domain", "queryLines": ["SELECT domain, COUNT(*) as violation_count FROM serverless_stable_s0v155_catalog.watchdog.violations WHERE status='open' GROUP BY domain ORDER BY violation_count DESC"]}, {"name": "ds_wd_domain_sev", "displayName": "Violations by Domain & Severity", "queryLines": ["SELECT domain, severity, COUNT(*) as violation_count FROM serverless_stable_s0v155_catalog.watchdog.violations WHERE status='open' GROUP BY domain, severity"]}, {"name": "ds_wd_owners", "displayName": "Owner Accountability", "queryLines": ["SELECT COALESCE(NULLIF(owner,''), 'Unassigned') as owner, COUNT(*) as total, SUM(CASE WHEN severity='critical' THEN 1 ELSE 0 END) as critical, SUM(CASE WHEN severity='high' THEN 1 ELSE 0 END) as high, SUM(CASE WHEN severity='medium' THEN 1 ELSE 0 END) as medium, SUM(CASE WHEN severity='low' THEN 1 ELSE 0 END) as low, COUNT(DISTINCT policy_id) as policies_violated FROM serverless_stable_s0v155_catalog.watchdog.violations WHERE status='open' GROUP BY COALESCE(NULLIF(owner,''), 'Unassigned') ORDER BY critical DESC, high DESC, total DESC LIMIT 15"]}, {"name": "ds_wd_top_policies", "displayName": "Top Policies by Violations", "queryLines": ["SELECT v.policy_id, v.severity, v.domain, COUNT(*) as violation_count, COUNT(DISTINCT v.resource_id) as resource_count FROM serverless_stable_s0v155_catalog.watchdog.violations v WHERE v.status='open' GROUP BY v.policy_id, v.severity, v.domain ORDER BY violation_count DESC LIMIT 10"]}, {"name": "ds_wd_ontology", "displayName": "Ontology Classes", "queryLines": ["SELECT class_name, COUNT(DISTINCT resource_id) as resource_count FROM serverless_stable_s0v155_catalog.watchdog.resource_classifications WHERE scan_id = (SELECT MAX(scan_id) FROM serverless_stable_s0v155_catalog.watchdog.resource_classifications) GROUP BY class_name ORDER BY resource_count DESC LIMIT 10"]}, {"name": "ds_wd_access_gov", "displayName": "Access Governance Violations", "queryLines": ["SELECT policy_id, COUNT(*) as violation_count FROM serverless_stable_s0v155_catalog.watchdog.violations WHERE status='open' AND policy_id LIKE 'POL-A%' GROUP BY policy_id ORDER BY violation_count DESC"]}, {"name": "ds_wd_access_counters", "displayName": "Access Counters", "queryLines": ["SELECT SUM(CASE WHEN policy_id='POL-A002' THEN 1 ELSE 0 END) as direct_user_grants, SUM(CASE WHEN policy_id='POL-A001' THEN 1 ELSE 0 END) as overprivileged FROM serverless_stable_s0v155_catalog.watchdog.violations WHERE status='open' AND policy_id LIKE 'POL-A%'"]}, {"name": "ds_wd_grants_detail", "displayName": "Direct Grants Detail", "queryLines": ["SELECT ri.metadata['grantee'] as grantee, ri.metadata['privilege'] as privilege, ri.metadata['securable_type'] as securable_type, ri.metadata['securable_full_name'] as securable_name FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory ri JOIN serverless_stable_s0v155_catalog.watchdog.violations v ON ri.resource_id = v.resource_id WHERE v.policy_id = 'POL-A002' AND v.status = 'open' AND ri.scan_id = (SELECT MAX(scan_id) FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory) AND ri.resource_type = 'grant' LIMIT 30"]}, {"name": "ds_wd_dq", "displayName": "DQ Monitoring", "queryLines": ["SELECT CASE WHEN tags['dqm_enabled'] = 'true' AND tags['lhm_enabled'] = 'true' THEN 'Both' WHEN tags['dqm_enabled'] = 'true' THEN 'DQM Only' WHEN tags['lhm_enabled'] = 'true' THEN 'LHM Only' ELSE 'None' END as monitoring_status, COUNT(*) as table_count FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory WHERE scan_id = (SELECT MAX(scan_id) FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory) AND resource_type = 'table' GROUP BY 1"]}, {"name": "ds_cross_violated_access", "displayName": "Violated Resources \u2014 Who Has Access", "queryLines": ["SELECT v.resource_name as table_name, v.severity, v.policy_id, p.privilege_type, p.grantee FROM serverless_stable_s0v155_catalog.watchdog.violations v JOIN system.information_schema.table_privileges p ON v.resource_name = p.table_name WHERE v.status = 'open' AND v.severity IN ('critical','high') AND p.table_catalog NOT IN ('system','samples') ORDER BY v.severity, v.resource_name LIMIT 30"]}, {"name": "ds_cross_untagged_violations", "displayName": "Untagged Tables with Violations", "queryLines": ["SELECT ri.resource_name, ri.owner, COUNT(DISTINCT v.violation_id) as open_violations, MAX(v.severity) as worst_severity FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory ri JOIN serverless_stable_s0v155_catalog.watchdog.violations v ON ri.resource_id = v.resource_id AND v.status = 'open' LEFT JOIN system.information_schema.table_tags tt ON ri.resource_name = tt.table_name AND tt.catalog_name NOT IN ('system','samples') WHERE ri.scan_id = (SELECT MAX(scan_id) FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory) AND ri.resource_type = 'table' AND tt.tag_name IS NULL GROUP BY ri.resource_name, ri.owner ORDER BY open_violations DESC LIMIT 20"]}], "pages": [{"name": "overview", "displayName": "Governance Overview", "pageType": "PAGE_TYPE_CANVAS", "layout": [{"widget": {"name": "p1-title", "multilineTextboxSpec": {"lines": ["## UC Governance Hub + Watchdog Compliance"]}}, "position": {"x": 0, "y": 0, "width": 6, "height": 1}}, {"widget": {"name": "p1-sub", "multilineTextboxSpec": {"lines": ["Unified view: UC metadata health (system tables) + policy compliance posture (Watchdog)"]}}, "position": {"x": 0, "y": 1, "width": 6, "height": 1}}, {"widget": {"nam