{"datasets": [{"name": "ds_agent_kpis", "displayName": "Agent KPIs", "queryLines": ["SELECT COUNT(*) AS total_agents, COUNT(CASE WHEN governance_status = 'governed' THEN 1 END) AS governed, COUNT(CASE WHEN governance_status = 'partially_governed' THEN 1 END) AS partially_governed, COUNT(CASE WHEN governance_status = 'ungoverned' THEN 1 END) AS ungoverned, ROUND(100.0 * COUNT(CASE WHEN governance_status = 'governed' THEN 1 END) / NULLIF(COUNT(*), 0), 1) AS governance_pct, SUM(open_violations) AS total_violations, SUM(critical_violations) AS critical_violations FROM serverless_stable_s0v155_catalog.watchdog.v_agent_inventory"]}, {"name": "ds_agent_by_status", "displayName": "Agents by Governance Status", "queryLines": ["SELECT governance_status, COUNT(*) AS agent_count FROM serverless_stable_s0v155_catalog.watchdog.v_agent_inventory GROUP BY governance_status"]}, {"name": "ds_agent_by_source", "displayName": "Agents by Source", "queryLines": ["SELECT agent_source, COUNT(*) AS agent_count FROM serverless_stable_s0v155_catalog.watchdog.v_agent_inventory GROUP BY agent_source ORDER BY agent_count DESC"]}, {"name": "ds_risk_distribution", "displayName": "Risk Distribution", "queryLines": ["SELECT risk_tier, COUNT(*) AS agent_count FROM serverless_stable_s0v155_catalog.watchdog.v_agent_risk_heatmap GROUP BY risk_tier ORDER BY CASE risk_tier WHEN 'critical' THEN 1 WHEN 'high' THEN 2 WHEN 'medium' THEN 3 ELSE 4 END"]}, {"name": "ds_agent_violations", "displayName": "Agent Violation Severity", "queryLines": ["SELECT v.severity, COUNT(*) AS violation_count FROM serverless_stable_s0v155_catalog.watchdog.violations v JOIN serverless_stable_s0v155_catalog.watchdog.resource_inventory ri ON v.resource_id = ri.resource_id WHERE v.status = 'open' AND ri.resource_type IN ('agent', 'agent_execution') AND ri.scan_id = (SELECT MAX(scan_id) FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory) GROUP BY v.severity ORDER BY CASE v.severity WHEN 'critical' THEN 1 WHEN 'high' THEN 2 WHEN 'medium' THEN 3 ELSE 4 END"]}, {"name": "ds_agent_inventory", "displayName": "Agent Inventory", "queryLines": ["SELECT resource_name AS agent_name, agent_source, COALESCE(agent_owner, owner, 'unassigned') AS owner, governance_status, environment, open_violations, critical_violations, high_violations, CASE WHEN accessed_pii = 'true' THEN 'Yes' ELSE 'No' END AS pii_access, CASE WHEN used_external_tool = 'true' THEN 'Yes' ELSE 'No' END AS external_access, CASE WHEN exported_data = 'true' THEN 'Yes' ELSE 'No' END AS data_export FROM serverless_stable_s0v155_catalog.watchdog.v_agent_inventory ORDER BY CASE governance_status WHEN 'ungoverned' THEN 1 WHEN 'partially_governed' THEN 2 ELSE 3 END, open_violations DESC"]}, {"name": "ds_top_violating_agents", "displayName": "Top Violating Agents", "queryLines": ["SELECT resource_name AS agent_name, open_violations, critical_violations, high_violations FROM serverless_stable_s0v155_catalog.watchdog.v_agent_inventory WHERE open_violations > 0 ORDER BY open_violations DESC LIMIT 15"]}, {"name": "ds_agent_policies", "displayName": "Agent Violations by Policy", "queryLines": ["SELECT v.policy_id, COALESCE(p.policy_name, v.policy_id) AS policy_name, v.severity, COUNT(*) AS violation_count FROM serverless_stable_s0v155_catalog.watchdog.violations v LEFT JOIN serverless_stable_s0v155_catalog.watchdog.policies p ON v.policy_id = p.policy_id WHERE v.status = 'open' AND v.policy_id LIKE 'POL-AGENT%' OR v.policy_id LIKE 'POL-EXEC%' GROUP BY v.policy_id, p.policy_name, v.severity ORDER BY violation_count DESC"]}, {"name": "ds_exec_kpis", "displayName": "Execution KPIs", "queryLines": ["SELECT COUNT(*) AS total_executions, COUNT(CASE WHEN compliance_status = 'compliant' THEN 1 END) AS compliant, COUNT(CASE WHEN compliance_status != 'compliant' THEN 1 END) AS non_compliant, ROUND(100.0 * COUNT(CASE WHEN compliance_status = 'compliant' THEN 1 END) / NULLIF(COUNT(*), 0), 1) AS compliance_pct FROM serverless_stable_s0v155_catalog.watchdog.v_agent_execution_compliance"]}, {"name": "ds_top_consumers", "displayName": "Top Consumers", "queryLines": ["SELECT endpoint_name, requester, request_count, total_input_tokens, total_output_tokens, compliance_status, CASE WHEN accessed_pii = 'true' THEN 'Yes' ELSE 'No' END AS pii_access, open_violations FROM serverless_stable_s0v155_catalog.watchdog.v_agent_execution_compliance ORDER BY request_count DESC LIMIT 20"]}, {"name": "ds_pii_access", "displayName": "PII Access Patterns", "queryLines": ["SELECT endpoint_name, COUNT(*) AS execution_count, SUM(request_count) AS total_requests, SUM(total_input_tokens) AS total_tokens FROM serverless_stable_s0v155_catalog.watchdog.v_agent_execution_compliance WHERE accessed_pii = 'true' GROUP BY endpoint_name ORDER BY total_requests DESC LIMIT 15"]}, {"name": "ds_exec_by_endpoint", "displayName": "Compliance by Endpoint", "queryLines": ["SELECT endpoint_name, COUNT(*) AS total_executions, COUNT(CASE WHEN compliance_status = 'compliant' THEN 1 END) AS compliant, COUNT(CASE WHEN compliance_status != 'compliant' THEN 1 END) AS non_compliant FROM serverless_stable_s0v155_catalog.watchdog.v_agent_execution_compliance GROUP BY endpoint_name ORDER BY non_compliant DESC LIMIT 15"]}, {"name": "ds_error_rates", "displayName": "Error Rates", "queryLines": ["SELECT endpoint_name, SUM(request_count) AS total_requests, SUM(error_count) AS total_errors, ROUND(100.0 * SUM(error_count) / NULLIF(SUM(request_count), 0), 2) AS error_rate_pct FROM serverless_stable_s0v155_catalog.watchdog.v_agent_execution_compliance WHERE error_count > 0 GROUP BY endpoint_name ORDER BY error_rate_pct DESC LIMIT 15"]}, {"name": "ds_risk_heatmap", "displayName": "Risk Heatmap", "queryLines": ["SELECT resource_name AS agent_name, agent_source, COALESCE(agent_owner, 'unassigned') AS owner, risk_tier, volume_tier, sensitivity_score, pii_access, external_access, data_export, total_requests, total_input_tokens, unique_requesters, total_errors, open_violations, critical_violations FROM serverless_stable_s0v155_catalog.watchdog.v_agent_risk_heatmap ORDER BY CASE risk_tier WHEN 'critical' THEN 1 WHEN 'high' THEN 2 WHEN 'medium' THEN 3 ELSE 4 END, total_requests DESC"]}, {"name": "ds_risk_tiers", "displayName": "Risk Tiers", "queryLines": ["SELECT risk_tier, COUNT(*) AS agent_count FROM serverless_stable_s0v155_catalog.watchdog.v_agent_risk_heatmap GROUP BY risk_tier"]}, {"name": "ds_sensitivity", "displayName": "Sensitivity Breakdown", "queryLines": ["SELECT resource_name AS agent_name, pii_access, external_access, data_export, sensitivity_score FROM serverless_stable_s0v155_catalog.watchdog.v_agent_risk_heatmap WHERE sensitivity_score > 0 ORDER BY sensitivity_score DESC, total_requests DESC LIMIT 20"]}], "pages": [{"name": "overview", "displayName": "Agent Overview", "pageType": "PAGE_TYPE_CANVAS", "layout": [{"widget": {"name": "p1-title", "multilineTextboxSpec": {"lines": ["## AI Agent Compliance Dashboard"]}}, "position": {"x": 0, "y": 0, "width": 6, "height": 1}}, {"widget": {"name": "p1-subtitle", "multilineTextboxSpec": {"lines": ["Governance posture across deployed AI agents and their execution traces"]}}, "position": {"x": 0, "y": 1, "width": 6, "height": 1}}, {"widget": {"name": "p1-total-agents", "queries": [{"name": "main_query", "query": {"datasetName": "ds_agent_kpis", "fields": [{"name": "total_agents", "expression": "`total_agents`"}], "disaggregated": true}}], "spec": {"version": 2, "widgetType": "counter", "encodings": {"value": {"fieldName": "total_agents", "displayName": "Total Agents"}}, "frame": {"showTitle": true, "title": "Total Agents"}}}, "position": {"x": 0, "y": 2, "width": 1, "height": 3}}, {"widget": {"name": "p1-governed", "queries": [{"name": "main_query", "query": {"datasetName": "ds_agent_kpis", "fields": [{"name": "governed", "expression": "`governed`"}], "disaggregated": true}}], "spec": {"version": 2, "widgetType": "counter", "encodings": {"value": {"fieldName": "governed", "displayName": "Gove