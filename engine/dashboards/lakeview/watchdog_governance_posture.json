{"datasets": [{"name": "ds_counters", "displayName": "Overview Counters", "queryLines": ["SELECT COUNT(*) as total_open, SUM(CASE WHEN severity='critical' THEN 1 ELSE 0 END) as critical_open, COUNT(DISTINCT resource_id) as resources_with_violations FROM serverless_stable_s0v155_catalog.watchdog.violations WHERE status='open'"]}, {"name": "ds_resources", "displayName": "Resources Scanned", "queryLines": ["SELECT COUNT(DISTINCT resource_id) as total_resources FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory WHERE scan_id = (SELECT MAX(scan_id) FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory)"]}, {"name": "ds_by_domain_severity", "displayName": "Violations by Domain & Severity", "queryLines": ["SELECT domain, severity, COUNT(*) as violation_count, COUNT(DISTINCT resource_id) as resource_count FROM serverless_stable_s0v155_catalog.watchdog.violations WHERE status='open' GROUP BY domain, severity ORDER BY domain"]}, {"name": "ds_by_domain", "displayName": "Violations by Domain", "queryLines": ["SELECT domain, COUNT(*) as violation_count FROM serverless_stable_s0v155_catalog.watchdog.violations WHERE status='open' GROUP BY domain ORDER BY violation_count DESC"]}, {"name": "ds_top_policies", "displayName": "Top Policies", "queryLines": ["SELECT v.policy_id, COALESCE(p.policy_name, v.policy_id) as policy_name, v.severity, COUNT(*) as violation_count, COUNT(DISTINCT v.resource_id) as resource_count FROM serverless_stable_s0v155_catalog.watchdog.violations v LEFT JOIN serverless_stable_s0v155_catalog.watchdog.policies p ON v.policy_id = p.policy_id WHERE v.status='open' GROUP BY v.policy_id, p.policy_name, v.severity ORDER BY violation_count DESC LIMIT 10"]}, {"name": "ds_owners", "displayName": "Owner Accountability", "queryLines": ["SELECT COALESCE(NULLIF(owner,''), 'Unassigned') as owner, COUNT(*) as total, SUM(CASE WHEN severity='critical' THEN 1 ELSE 0 END) as critical, SUM(CASE WHEN severity='high' THEN 1 ELSE 0 END) as high, SUM(CASE WHEN severity='medium' THEN 1 ELSE 0 END) as medium, SUM(CASE WHEN severity='low' THEN 1 ELSE 0 END) as low, COUNT(DISTINCT policy_id) as policies_violated, COUNT(DISTINCT domain) as domains FROM serverless_stable_s0v155_catalog.watchdog.violations WHERE status='open' GROUP BY COALESCE(NULLIF(owner,''), 'Unassigned') ORDER BY critical DESC, high DESC, total DESC LIMIT 15"]}, {"name": "ds_resource_compliance", "displayName": "Resource Compliance", "queryLines": ["SELECT ri.resource_id, ri.resource_type, ri.resource_name, ri.owner, rc.class_name as ontology_class, COUNT(DISTINCT v.violation_id) as open_violations FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory ri LEFT JOIN serverless_stable_s0v155_catalog.watchdog.resource_classifications rc ON ri.resource_id = rc.resource_id AND ri.scan_id = rc.scan_id LEFT JOIN serverless_stable_s0v155_catalog.watchdog.violations v ON ri.resource_id = v.resource_id AND v.status = 'open' WHERE ri.scan_id = (SELECT MAX(scan_id) FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory) GROUP BY ri.resource_id, ri.resource_type, ri.resource_name, ri.owner, rc.class_name HAVING COUNT(DISTINCT v.violation_id) > 0 ORDER BY open_violations DESC LIMIT 30"]}, {"name": "ds_ontology", "displayName": "Ontology Classes", "queryLines": ["SELECT class_name, COUNT(DISTINCT resource_id) as resource_count FROM serverless_stable_s0v155_catalog.watchdog.resource_classifications WHERE scan_id = (SELECT MAX(scan_id) FROM serverless_stable_s0v155_catalog.watchdog.resource_classifications) GROUP BY class_name ORDER BY resource_count DESC LIMIT 10"]}, {"name": "ds_access_gov", "displayName": "Access Governance", "queryLines": ["SELECT policy_id, COUNT(*) as violation_count, COUNT(DISTINCT resource_id) as resource_count FROM serverless_stable_s0v155_catalog.watchdog.violations WHERE status='open' AND policy_id LIKE 'POL-A%' GROUP BY policy_id ORDER BY violation_count DESC"]}, {"name": "ds_access_counters", "displayName": "Access Counters", "queryLines": ["SELECT SUM(CASE WHEN policy_id='POL-A002' THEN 1 ELSE 0 END) as direct_user_grants, SUM(CASE WHEN policy_id='POL-A001' THEN 1 ELSE 0 END) as overprivileged_grants FROM serverless_stable_s0v155_catalog.watchdog.violations WHERE status='open' AND policy_id LIKE 'POL-A%'"]}, {"name": "ds_grants_detail", "displayName": "Direct Grants Detail", "queryLines": ["SELECT ri.metadata['grantee'] as grantee, ri.metadata['privilege'] as privilege, ri.metadata['securable_type'] as securable_type, ri.metadata['securable_full_name'] as securable_name FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory ri JOIN serverless_stable_s0v155_catalog.watchdog.violations v ON ri.resource_id = v.resource_id WHERE v.policy_id = 'POL-A002' AND v.status = 'open' AND ri.scan_id = (SELECT MAX(scan_id) FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory) AND ri.resource_type = 'grant' LIMIT 30"]}, {"name": "ds_dq_monitoring", "displayName": "DQ Monitoring", "queryLines": ["SELECT CASE WHEN tags['dqm_enabled'] = 'true' AND tags['lhm_enabled'] = 'true' THEN 'Both' WHEN tags['dqm_enabled'] = 'true' THEN 'DQM Only' WHEN tags['lhm_enabled'] = 'true' THEN 'LHM Only' ELSE 'None' END as monitoring_status, COUNT(*) as table_count FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory WHERE scan_id = (SELECT MAX(scan_id) FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory) AND resource_type = 'table' GROUP BY 1"]}, {"name": "ds_unmonitored", "displayName": "Unmonitored Tables", "queryLines": ["SELECT resource_name, owner, domain as catalog_name FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory WHERE scan_id = (SELECT MAX(scan_id) FROM serverless_stable_s0v155_catalog.watchdog.resource_inventory) AND resource_type = 'table' AND (tags['dqm_enabled'] IS NULL OR tags['dqm_enabled'] != 'true') AND (tags['lhm_enabled'] IS NULL OR tags['lhm_enabled'] != 'true') ORDER BY domain, resource_name LIMIT 20"]}], "pages": [{"name": 